<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Survey Analytics</title>
    <!-- Bootstrap 5 for layout -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #1a3a5c;
            --accent: #e8a020;
            --light: #f5f8fc;
        }

        body {
            background: var(--light);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        /* ── Header ── */
        .survey-header {
            background: var(--primary);
            color: #fff;
            padding: 2rem 0 1.4rem;
            text-align: center;
        }

        .survey-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: .4rem;
        }

        .table-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(0, 0, 0, .05);
            padding: 2rem;
            margin-bottom: 3rem;
        }

        .table-card h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 1.5rem;
        }
    </style>
</head>

<body>
    <!-- Header -->
    <header class="survey-header" role="banner">
        <h1><em>Survey Analytics Dashboard</em></h1>
        <p class="mb-0 text-white-50">Visualizing Website UI Evaluation Results</p>
    </header>

    <main class="container py-5">

        <!-- Survey Entries Log Table -->
        <div class="table-card">
            <h2>Survey Entries Log</h2>
            <% if (typeof entries !=='undefined' && entries && entries.length) { %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover mt-3">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Navigation</th>
                                <th>Design</th>
                                <th>Features</th>
                                <th>Problems</th>
                                <th>Comments</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% entries.forEach(function(entry, index) { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= entry.name || '-' %>
                                    </td>
                                    <td>
                                        <%= entry.navigation || '-' %>
                                    </td>
                                    <td>
                                        <%= entry.design || '-' %>
                                    </td>
                                    <td>
                                        <% if (Array.isArray(entry.features)) { %>
                                            <%= entry.features.join(', ') %>
                                        <% } else if (entry.features) { %>
                                            <%= entry.features %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                    <td><%= entry.problems || ' -' %>
                                    </td>
                                    <td>
                                        <%= entry.comments || '-' %>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                    <p class="text-muted">No survey entries have been logged yet.</p>
                    <% } %>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>